import "std/io"
import "std/lib"

static input byte 256

static file ptr 1
static size qword 1
static buffer ptr 1

proc main ( qword ptr ) qword :
    swap
    if dup 2 < do
        swap . "Usage: %s <file>" $1 @println
        1 exit
    else end
    
    drop 1 [] "rb" over fopen!

    if dup @NULL ==
    do
        pick 1 "Failed to open file %s" $1 @println
        1 exit
    else end

    swap "Opened file: %s" $1 @println
    
    dup @SEEK_END 0 rot fseek!

    dup ftell!      
    .size over =
    drop
    
    dup rewind!
    .file over =    # Spara fp i .file
    
    .size . 1 + alloc
    if dup @NULL ==
    do
        "Failed to allocate memory for file content!" puts!
        1 exit
    else end

    .buffer over =
    drop            
    
    .file .
    .size .
    1
    .buffer .
    
    fread!
    drop

    .file . fclose!

    .buffer . .size . 0 []=
    
    .buffer . "%s" $1 @println

    .buffer . free

    0 return
end
